# defi-ops credentials template — copy to .env, chmod 600, NEVER commit.

# === Telegram (read + write) ===
# api_id + hash — https://my.telegram.org (one-time)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+

# Bot token — from @BotFather (can reuse the one from ~/.openclaw/openclaw.json
# if openclaw's defi-monitor-30m is disabled first)
TELEGRAM_BOT_TOKEN=

# Target chat + topic (for send)
TELEGRAM_CHAT_ID=-1003981168546
TELEGRAM_TOPIC_ID=

# Allowlisted operator user id (only replies from this user trigger record.py)
TELEGRAM_OPERATOR_ID=365840120

# === On-chain (read-only) ===
ETHERSCAN_API_KEY=
ARKHAM_API_KEY=
HELIUS_API_KEY=

# === Optional ===
# ANTHROPIC_API_KEY=
# DEFILLAMA_BASE=https://api.llama.fi
